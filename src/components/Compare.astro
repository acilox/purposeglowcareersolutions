---
const rows = [
  'ATS keyword optimization',
  'Achievement-focused, quantified bullets',
  'Modern, recruiter-friendly design',
  'Tailored to your target role',
  'Expert second set of eyes',
  'PDF + editable Word files',
  'Done in 24 hours (not your whole weekend)',
];
---

<section class="section">
  <div class="container-x">
    <div class="max-w-2xl reveal">
      <p class="eyebrow text-violet">Why not DIY?</p>
      <h2 class="display-2 mt-3">Going it alone vs. the Glow Up treatment.</h2>
      <p class="mt-5 text-lg text-ink/75">You could spend the weekend wrestling with formatting — or let an expert handle it while you focus on the interview.</p>
    </div>

    <div class="mt-10 card overflow-hidden reveal reveal-delay-1 max-w-3xl">
      <div class="grid grid-cols-[1fr_5.5rem_6.5rem] sm:grid-cols-[1fr_8rem_9rem]">
        <!-- header -->
        <div class="p-4 md:p-5"></div>
        <div class="p-4 md:p-5 text-center border-l border-lavender/40">
          <span class="block text-xs sm:text-sm font-semibold text-ink/55">On your own</span>
        </div>
        <div class="p-4 md:p-5 text-center border-l border-lavender/40 bg-lavender-soft/50">
          <span class="block text-xs sm:text-sm font-semibold text-violet">The Glow Up ✦</span>
        </div>

        {rows.map((label) => (
          <>
            <div class="p-4 md:px-5 text-sm text-ink/80 border-t border-lavender/40">{label}</div>
            <div class="p-4 grid place-items-center border-t border-l border-lavender/40">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#cbb8f0" stroke-width="2.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </div>
            <div class="p-4 grid place-items-center border-t border-l border-lavender/40 bg-lavender-soft/40">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2.8"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
          </>
        ))}
      </div>
    </div>
  </div>
</section>
