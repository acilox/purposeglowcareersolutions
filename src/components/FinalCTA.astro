---
import { site, mailto } from '../data/site';
---

<section id="contact" class="section">
  <div class="container-x">
    <div class="relative overflow-hidden rounded-[2.5rem] bg-gradient-glow px-6 py-16 md:py-20 text-center reveal">
      <!-- soft inner glow -->
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(255,255,255,0.35),transparent_55%)]" aria-hidden="true"></div>

      <div class="relative max-w-2xl mx-auto text-white">
        <p class="eyebrow text-white/85">Your next chapter starts here</p>
        <h2 class="font-display font-semibold mt-4 text-white" style="font-size:clamp(2rem,5vw,3.25rem); line-height:1.05;">
          Ready to stand out and get hired?
        </h2>
        <p class="mt-5 text-lg text-white/90">
          Let's build a résumé that opens doors. Start your intake form now — I'll be in touch within 24 hours.
        </p>

        <div class="mt-9 flex flex-wrap gap-3 justify-center">
          <a href={site.intakeForm} target="_blank" rel="noopener" class="btn bg-white text-plum hover:!bg-white hover:-translate-y-0.5 shadow-lg">
            Start Your Glow Up ✦
          </a>
          <a href={mailto} class="btn border border-white/70 text-white hover:bg-white/10">
            Email Nicole
          </a>
        </div>

        <div class="mt-8 flex items-center justify-center gap-5 text-white/90">
          <a href={site.socials.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="hover:text-white">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href={site.socials.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" class="hover:text-white">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 5a1.94 1.94 0 11-3.88 0 1.94 1.94 0 013.88 0zM3.4 8.5h3.1V21H3.4V8.5zM9 8.5h2.97v1.7h.04c.41-.78 1.42-1.6 2.93-1.6 3.13 0 3.71 2.06 3.71 4.74V21h-3.1v-5.4c0-1.29-.02-2.95-1.8-2.95-1.8 0-2.08 1.4-2.08 2.85V21H9V8.5z"/></svg>
          </a>
          <span class="text-sm">·</span>
          <a href={mailto} class="text-sm hover:text-white">{site.email}</a>
        </div>
      </div>
    </div>
  </div>
</section>
