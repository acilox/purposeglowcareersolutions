---
import { site } from '../data/site';
// Generic example résumé (not a real person) used only to demonstrate the transformation.
---

<section id="glowup" class="section">
  <div class="container-x">
    <div class="max-w-2xl reveal">
      <span class="chip">✦ See the transformation</span>
      <h2 class="display-2 mt-4">Watch an ordinary résumé <span class="text-gradient">glow up</span>.</h2>
      <p class="mt-5 text-lg text-ink/75">
        Drag the slider to see the difference a strategic rewrite makes — from a cramped wall of text
        that ATS software skips, to a clean, keyword-rich résumé recruiters actually read.
      </p>
    </div>

    <div class="mt-10 grid lg:grid-cols-[1.15fr_0.85fr] gap-10 items-center">
      <!-- The comparison slider -->
      <div class="reveal reveal-delay-1">
        <div data-ba class="ba card mx-auto w-full max-w-xl aspect-[4/5] bg-white">
          <!-- AFTER (bottom layer, fully visible on the right) -->
          <div class="ba__layer ba__after">
            <div class="rz">
              <div class="flex items-start gap-3 pb-2 border-b-2" style="border-color:var(--color-lavender)">
                <div class="w-9 h-9 rounded-full bg-gradient-glow shrink-0"></div>
                <div class="flex-1">
                  <div class="font-display font-bold" style="color:var(--color-plum);font-size:0.95rem;line-height:1">Jordan Reyes</div>
                  <div style="color:var(--color-rose);font-weight:600;font-size:0.62rem">Registered Nurse → Healthcare Administrator</div>
                </div>
                <span class="text-[0.5rem] font-bold px-1.5 py-0.5 rounded-full" style="background:var(--color-lavender-soft);color:var(--color-violet)">ATS ✓</span>
              </div>
              <div class="mt-2.5">
                <div class="text-[0.6rem] font-bold uppercase tracking-wide" style="color:var(--color-violet)">Summary</div>
                <div class="rz-line mt-1" style="width:100%;background:#e9e4f5"></div>
                <div class="rz-line mt-1" style="width:88%;background:#e9e4f5"></div>
              </div>
              <div class="mt-2.5">
                <div class="text-[0.6rem] font-bold uppercase tracking-wide" style="color:var(--color-violet)">Experience</div>
                {[1,2,3].map(() => (
                  <div class="flex gap-1.5 mt-1 items-start">
                    <span class="mt-0.5 w-1.5 h-1.5 rounded-full shrink-0" style="background:var(--color-rose)"></span>
                    <span class="rz-line" style="width:92%;background:#e9e4f5"></span>
                  </div>
                ))}
              </div>
              <div class="mt-2.5">
                <div class="text-[0.6rem] font-bold uppercase tracking-wide" style="color:var(--color-violet)">Skills</div>
                <div class="flex flex-wrap gap-1 mt-1">
                  {['EMR','Compliance','Leadership','Billing','Patient Care'].map((s) => (
                    <span class="text-[0.5rem] px-1.5 py-0.5 rounded-full" style="background:var(--color-rose-soft);color:var(--color-plum)">{s}</span>
                  ))}
                </div>
              </div>
            </div>
            <span class="ba__tag" style="right:0.75rem;background:var(--color-violet)">After ✦</span>
          </div>

          <!-- BEFORE (top layer, clipped) -->
          <div class="ba__layer ba__before bg-[#f3f3f3]">
            <div class="rz" style="color:#8a8a8a">
              <div class="text-center pb-1.5" style="border-bottom:1px solid #cfcfcf">
                <div style="font-weight:700;color:#5a5a5a;font-size:0.8rem">JORDAN REYES</div>
                <div style="font-size:0.55rem">jreyes@email.com · 555-0100 · City, ST</div>
              </div>
              <div class="mt-2">
                <div style="font-size:0.58rem;font-weight:700;color:#6a6a6a">OBJECTIVE</div>
                <div class="rz-line mt-1" style="width:100%;background:#d9d9d9"></div>
                <div class="rz-line mt-1" style="width:97%;background:#d9d9d9"></div>
                <div class="rz-line mt-1" style="width:99%;background:#d9d9d9"></div>
                <div class="rz-line mt-1" style="width:70%;background:#d9d9d9"></div>
              </div>
              <div class="mt-2">
                <div style="font-size:0.58rem;font-weight:700;color:#6a6a6a">WORK HISTORY</div>
                {[1,2,3,4,5,6].map(() => (
                  <div class="rz-line mt-1" style="width:99%;background:#d9d9d9"></div>
                ))}
              </div>
              <div class="mt-2">
                <div style="font-size:0.58rem;font-weight:700;color:#6a6a6a">DUTIES</div>
                {[1,2,3,4].map(() => (
                  <div class="rz-line mt-1" style="width:99%;background:#d9d9d9"></div>
                ))}
              </div>
            </div>
            <span class="ba__tag" style="left:0.75rem;background:#9ca3af">Before</span>
          </div>

          <!-- handle + range -->
          <div class="ba__handle" style="left:50%">
            <span class="ba__grip">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="m9 6-4 6 4 6M15 6l4 6-4 6"/></svg>
            </span>
          </div>
          <input class="ba__range" type="range" min="0" max="100" value="50" aria-label="Reveal before and after résumé" />
        </div>
        <p class="text-center text-xs text-ink/50 mt-3">← drag to compare · illustrative example</p>
      </div>

      <!-- What changed -->
      <div class="reveal reveal-delay-2">
        <h3 class="text-2xl">What actually changes</h3>
        <ul class="mt-5 space-y-4">
          {[
            ['Beats the ATS', 'Right keywords and clean structure so software ranks you higher — not screens you out.'],
            ['Leads with results', 'Vague “duties” become quantified wins that make recruiters stop scrolling.'],
            ['Reads in 6 seconds', 'Clear sections and hierarchy guide the eye to what matters, fast.'],
            ['Looks the part', 'A polished, modern design that signals “senior” before a word is read.'],
          ].map(([t, d]) => (
            <li class="flex gap-3">
              <span class="mt-0.5 w-6 h-6 rounded-full bg-gradient-glow grid place-items-center shrink-0">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
              <span><strong class="text-plum">{t}.</strong> <span class="text-ink/70">{d}</span></span>
            </li>
          ))}
        </ul>
        <a href={site.intakeForm} target="_blank" rel="noopener" data-magnetic class="btn btn-primary mt-7">Glow up my résumé ✦</a>
      </div>
    </div>
  </div>
</section>
