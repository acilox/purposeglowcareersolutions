---
import { site } from '../data/site';

const tiers = [
  {
    name: 'The Refresh',
    price: '75',
    tagline: 'Polish what you have',
    features: ['Full résumé rewrite & reformat', 'ATS keyword optimization', 'Modern, clean design', 'PDF + Word files', '24-hour turnaround'],
    featured: false,
  },
  {
    name: 'The Glow Up',
    price: '100',
    tagline: 'Most popular',
    features: ['Everything in The Refresh', 'Deeper strategy & positioning', 'Achievement-focused bullet points', 'Tailored to your target role', 'One round of revisions'],
    featured: true,
  },
  {
    name: 'Career Glow Package',
    price: '140',
    tagline: 'The full transformation',
    features: ['Everything in The Glow Up', 'Matching cover letter', 'LinkedIn profile optimization', 'Personal branding polish', 'Priority support'],
    featured: false,
  },
];

const addons = [
  { name: 'Cover Letter Add-On', price: '+$40', desc: 'Personalized, industry-tailored' },
  { name: 'LinkedIn Bio Add-On', price: '+$40', desc: 'Keyword-optimized personal branding' },
];
---

<section id="services" class="section">
  <div class="container-x">
    <div class="max-w-2xl reveal">
      <p class="eyebrow text-rose">Services & pricing</p>
      <h2 class="display-2 mt-3">Simple, honest pricing.</h2>
      <p class="mt-5 text-lg text-ink/75">Pick the level of glow that fits where you are. No subscriptions, no surprises.</p>
    </div>

    <div class="mt-12 grid md:grid-cols-3 gap-6 items-start">
      {tiers.map((t, i) => (
        <div class={`card p-8 relative reveal reveal-delay-${(i % 3) + 1} ${t.featured ? 'ring-2 ring-violet md:-translate-y-3 shadow-xl' : 'card-hover'}`}>
          {t.featured && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gradient-glow text-white text-xs font-semibold px-4 py-1 rounded-full shadow">★ Most Popular</span>
          )}
          <p class="text-sm font-semibold text-rose">{t.tagline}</p>
          <h3 class="mt-1 text-2xl">{t.name}</h3>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="font-display text-5xl font-bold text-plum">${t.price}</span>
          </div>
          <ul class="mt-6 space-y-3">
            {t.features.map((f) => (
              <li class="flex gap-2.5 text-sm text-ink/80">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2.5" class="mt-0.5 shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href={site.intakeForm} target="_blank" rel="noopener" class={`btn w-full mt-8 ${t.featured ? 'btn-primary' : 'btn-ghost'}`}>Choose {t.name.replace('The ', '')}</a>
        </div>
      ))}
    </div>

    <!-- add-ons -->
    <div class="mt-8 grid sm:grid-cols-2 gap-4">
      {addons.map((a) => (
        <div class="card glass p-5 flex items-center justify-between reveal">
          <div>
            <p class="font-semibold text-plum">{a.name}</p>
            <p class="text-sm text-ink/65">{a.desc}</p>
          </div>
          <span class="font-display text-2xl font-bold text-gradient">{a.price}</span>
        </div>
      ))}
    </div>
    <p class="mt-6 text-sm text-ink/60 reveal">Payments accepted via Venmo or Square invoice. Not sure which package fits? <a href={site.intakeForm} target="_blank" rel="noopener" class="text-violet font-medium underline underline-offset-2">Start the intake form</a> and I'll recommend the right one.</p>
  </div>
</section>
