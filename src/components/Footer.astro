---
import { site, mailto } from '../data/site';
---

<footer class="relative mt-8 border-t border-lavender/60">
  <div class="container-x py-14 grid gap-10 md:grid-cols-3">
    <div>
      <a href="#top" class="flex items-center gap-2.5 font-display text-lg font-semibold text-plum">
        <span class="grid place-items-center w-9 h-9 rounded-xl bg-gradient-glow text-white">✦</span>
        Purpose <span class="text-gradient">&amp; Glow</span>
      </a>
      <p class="mt-4 text-sm text-ink/70 max-w-xs">{site.tagline} Résumé writing, cover letters & LinkedIn optimization by Nicole.</p>
    </div>

    <div>
      <h4 class="text-sm font-semibold text-plum mb-3">Explore</h4>
      <ul class="space-y-2 text-sm text-ink/75">
        <li><a href="#services" class="hover:text-violet">Services & Pricing</a></li>
        <li><a href="#about" class="hover:text-violet">About Nicole</a></li>
        <li><a href="#results" class="hover:text-violet">Client Results</a></li>
        <li><a href="#faq" class="hover:text-violet">FAQ</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-semibold text-plum mb-3">Get in touch</h4>
      <ul class="space-y-2 text-sm text-ink/75">
        <li><a href={mailto} class="hover:text-violet">{site.email}</a></li>
        <li><a href={site.intakeForm} target="_blank" rel="noopener" class="hover:text-violet">Fill out the intake form →</a></li>
      </ul>
      <div class="flex gap-3 mt-4">
        <a href={site.socials.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="grid place-items-center w-9 h-9 rounded-lg bg-white border border-lavender hover:border-violet transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-plum"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href={site.socials.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" class="grid place-items-center w-9 h-9 rounded-lg bg-white border border-lavender hover:border-violet transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-plum"><path d="M6.94 5a1.94 1.94 0 11-3.88 0 1.94 1.94 0 013.88 0zM3.4 8.5h3.1V21H3.4V8.5zM9 8.5h2.97v1.7h.04c.41-.78 1.42-1.6 2.93-1.6 3.13 0 3.71 2.06 3.71 4.74V21h-3.1v-5.4c0-1.29-.02-2.95-1.8-2.95-1.8 0-2.08 1.4-2.08 2.85V21H9V8.5z"/></svg>
        </a>
        <a href={site.socials.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="grid place-items-center w-9 h-9 rounded-lg bg-white border border-lavender hover:border-violet transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-plum"><path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.53-1.5H17V3.6c-.28-.04-1.24-.12-2.36-.12-2.33 0-3.94 1.42-3.94 4.03v2.25H8v3.1h2.7V21h2.8z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-lavender/50">
    <div class="container-x py-5 text-xs text-ink/55 flex flex-col sm:flex-row justify-between gap-2">
      <p>© {new Date().getFullYear()} {site.name}. All rights reserved.</p>
      <p>Crafted with care for job seekers who are ready to glow. ✦</p>
    </div>
  </div>
</footer>
