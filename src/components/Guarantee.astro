---
// NOTE for Nicole: confirm these promises match how you work before go-live
// (esp. revisions policy). Tweak copy in this file as needed.
const promises = [
  { icon: '<path d="M12 2 4 5v6c0 5 3.4 8.6 8 11 4.6-2.4 8-6 8-11V5l-8-3Z"/><path d="m9 12 2 2 4-4"/>', title: 'Revisions included', body: "We fine-tune until it feels like you — polished and proud." },
  { icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/>', title: 'Personal 1:1 attention', body: 'You work directly with Nicole — never a template on autopilot.' },
  { icon: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>', title: 'Secure & simple payment', body: 'Pay easily via Venmo or a Square invoice. No accounts, no hassle.' },
  { icon: '<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>', title: '24-hour turnaround', body: 'Most résumés are back in your inbox within a day.' },
];
---

<section class="section pt-0">
  <div class="container-x">
    <div class="border-glow p-8 md:p-10 reveal">
      <div class="text-center max-w-xl mx-auto">
        <span class="chip">Your peace of mind</span>
        <h2 class="text-3xl mt-4">Booking is risk-free.</h2>
        <p class="mt-3 text-ink/70">I want you to feel completely confident — before, during, and after.</p>
      </div>
      <div class="mt-9 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {promises.map((p) => (
          <div class="text-center">
            <span class="mx-auto w-12 h-12 rounded-2xl bg-gradient-glow grid place-items-center">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" set:html={p.icon} />
            </span>
            <h3 class="mt-4 text-lg">{p.title}</h3>
            <p class="mt-1.5 text-sm text-ink/65">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
