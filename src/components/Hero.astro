---
import { site, mailto } from '../data/site';
---

<section id="top" class="section overflow-hidden" style="padding-top: clamp(7rem, 15vw, 9.5rem);">
  <div class="aurora-hero" aria-hidden="true"></div>
  <div class="hero-glow hero-glow--a" aria-hidden="true"></div>
  <div class="hero-glow hero-glow--b" aria-hidden="true"></div>
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="sparkles" aria-hidden="true">
    <span class="sparkle" style="left:8%; animation-delay:0s; font-size:0.8rem">✦</span>
    <span class="sparkle" style="left:22%; animation-delay:2.4s; font-size:1.1rem">✦</span>
    <span class="sparkle" style="left:40%; animation-delay:4.1s; font-size:0.7rem">✧</span>
    <span class="sparkle" style="left:58%; animation-delay:1.2s; font-size:1rem">✦</span>
    <span class="sparkle" style="left:73%; animation-delay:3.3s; font-size:0.85rem">✧</span>
    <span class="sparkle" style="left:88%; animation-delay:5.2s; font-size:1.15rem">✦</span>
    <span class="sparkle" style="left:31%; animation-delay:6.1s; font-size:0.75rem">✦</span>
    <span class="sparkle" style="left:66%; animation-delay:0.8s; font-size:0.7rem">✧</span>
  </div>
  <div class="container-x grid lg:grid-cols-[1.05fr_0.95fr] gap-12 lg:gap-14 items-center relative z-10">
    <!-- Copy -->
    <div class="text-center lg:text-left">
      <p class="eyebrow text-violet reveal">Résumés · Cover Letters · LinkedIn</p>
      <h1 class="display-1 mt-4 reveal reveal-delay-1">
        Your résumé,<br />
        ready to <span id="rotator" class="text-gradient">glow.</span>
      </h1>
      <p class="mt-6 text-lg md:text-xl text-ink/75 max-w-xl mx-auto lg:mx-0 reveal reveal-delay-2">
        Recruiters spend <strong class="text-plum">six seconds</strong> on a résumé. I write ATS-friendly,
        interview-winning résumés that make those seconds count — so you can feel confident every time you
        click <em>Submit Application</em>.
      </p>

      <div class="mt-8 flex flex-wrap gap-3 justify-center lg:justify-start reveal reveal-delay-3">
        <a href={site.intakeForm} target="_blank" rel="noopener" data-magnetic class="btn btn-primary pulse-cta">Start Your Glow Up ✦</a>
        <a href={mailto} class="btn btn-ghost">Book a Free Consultation</a>
      </div>
      <p class="mt-3 text-sm text-ink/55 reveal reveal-delay-3">Free consult · No obligation · Delivered in 24 hours</p>

      <!-- mini trust row -->
      <div class="mt-9 flex flex-wrap items-center justify-center lg:justify-start gap-2.5 text-sm reveal reveal-delay-3">
        <div class="flex items-center gap-2 rounded-full bg-white/65 backdrop-blur border border-white/70 px-3.5 py-1.5 shadow-sm">
          <span class="text-glow">★★★★★</span>
          <span class="text-ink/75 font-medium">5.0 from real clients</span>
        </div>
        <div class="flex items-center gap-2 rounded-full bg-white/65 backdrop-blur border border-white/70 px-3.5 py-1.5 shadow-sm text-ink/75">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg>
          24-hour turnaround
        </div>
        <div class="flex items-center gap-2 rounded-full bg-white/65 backdrop-blur border border-white/70 px-3.5 py-1.5 shadow-sm text-ink/75">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#db2777" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg>
          PDF + Word
        </div>
      </div>
    </div>

    <!-- Résumé visual -->
    <div class="relative reveal reveal-delay-2">
      <div class="card floaty shine p-6 md:p-7 max-w-md mx-auto rotate-[1.5deg]">
        <div class="flex items-center gap-4 border-b border-lavender/60 pb-4">
          <div class="w-14 h-14 rounded-full bg-gradient-glow grid place-items-center text-white font-display text-xl">✦</div>
          <div>
            <div class="h-3.5 w-40 rounded bg-plum/80"></div>
            <div class="h-2.5 w-28 rounded bg-rose/50 mt-2"></div>
          </div>
          <span class="ml-auto text-[0.65rem] font-semibold px-2 py-1 rounded-full bg-lavender-soft text-violet">ATS&nbsp;✓</span>
        </div>
        <div class="mt-4 space-y-2.5">
          <div class="h-2.5 w-full rounded bg-ink/10"></div>
          <div class="h-2.5 w-11/12 rounded bg-ink/10"></div>
          <div class="h-2.5 w-4/5 rounded bg-ink/10"></div>
        </div>
        <div class="mt-5 grid grid-cols-3 gap-2">
          <div class="h-12 rounded-lg bg-lavender-soft"></div>
          <div class="h-12 rounded-lg bg-rose-soft/60"></div>
          <div class="h-12 rounded-lg bg-amber-100"></div>
        </div>
        <div class="mt-4 space-y-2.5">
          <div class="h-2.5 w-full rounded bg-ink/10"></div>
          <div class="h-2.5 w-10/12 rounded bg-ink/10"></div>
        </div>
      </div>

      <!-- floating badges -->
      <div class="absolute -top-4 -left-2 sm:-left-6 card glass px-4 py-3 rotate-[-4deg]">
        <div class="text-2xl font-display font-bold text-gradient">95%</div>
        <div class="text-[0.7rem] text-ink/70 -mt-0.5">interview rate</div>
      </div>
      <div class="absolute -bottom-5 right-0 sm:-right-4 card glass px-4 py-3 rotate-[3deg]">
        <div class="text-2xl font-display font-bold text-plum">75+</div>
        <div class="text-[0.7rem] text-ink/70 -mt-0.5">résumés transformed</div>
      </div>
    </div>
  </div>
</section>
