---
import { site } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { href: '#glowup', label: 'Before & After' },
  { href: '#services', label: 'Services' },
  { href: '#about', label: 'About' },
  { href: '#results', label: 'Results' },
  { href: `${base}/checklist`, label: 'Free Guide' },
];
---

<header class="fixed top-0 inset-x-0 z-40">
  <nav id="siteNav" class="glass border-b border-white/50">
    <div class="container-x flex items-center justify-between h-16 md:h-[4.5rem]">
      <!-- Logo -->
      <a href="#top" class="flex items-center gap-2 shrink-0">
        <span class="grid place-items-center w-9 h-9 rounded-xl bg-gradient-glow text-white shadow-sm shrink-0">✦</span>
        <span class="font-display font-semibold text-plum leading-none text-[1.05rem] sm:text-lg whitespace-nowrap">
          Purpose <span class="text-gradient">&amp; Glow</span>
        </span>
      </a>

      <!-- Desktop links -->
      <ul class="hidden md:flex items-center gap-7 text-sm font-medium text-ink/80">
        {links.map((l) => (
          <li><a href={l.href} class="hover:text-violet transition-colors">{l.label}</a></li>
        ))}
      </ul>

      <!-- Actions -->
      <div class="flex items-center gap-2.5">
        <a href={site.intakeForm} target="_blank" rel="noopener" data-magnetic class="btn btn-primary hidden sm:inline-flex !py-2.5 !px-5 text-sm">
          Start Your Glow Up
        </a>
        <button id="navToggle" class="md:hidden grid place-items-center w-11 h-11 rounded-xl border border-lavender bg-white/80 text-plum active:scale-95 transition-transform" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu">
          <svg class="i-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
          <svg class="i-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6l12 12M18 6 6 18"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobileMenu" class="hidden md:hidden border-t border-white/50 bg-white/95 backdrop-blur-lg">
      <ul class="container-x py-3 flex flex-col text-ink/85">
        {links.map((l) => (
          <li><a href={l.href} class="block py-3 font-medium hover:text-violet border-b border-lavender/30">{l.label}</a></li>
        ))}
        <li class="pt-3 pb-1">
          <a href={site.intakeForm} target="_blank" rel="noopener" class="btn btn-primary w-full">Start Your Glow Up ✦</a>
        </li>
      </ul>
    </div>
  </nav>
</header>
