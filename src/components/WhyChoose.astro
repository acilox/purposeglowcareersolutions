---
const features = [
  { icon: '🎯', title: 'ATS-Friendly by Design', body: 'Formatted and keyword-optimized to pass applicant tracking systems — then written to impress the human who reads it next.' },
  { icon: '🤝', title: 'One-on-One Support', body: 'You work directly with Nicole — no templates on autopilot. Every document is tailored to your goals and voice.' },
  { icon: '⚡', title: '24-Hour Turnaround', body: 'Need it fast? Most résumés are delivered within a day, so you never miss a deadline or an opportunity.' },
  { icon: '🩺', title: 'Career-Change Specialist', body: '10+ years in healthcare & operations means I know how to translate your experience — including big pivots — into transferable strengths.' },
  { icon: '📄', title: 'PDF + Word, Every Time', body: 'You get polished, editable files in both formats so you can apply anywhere with confidence.' },
  { icon: '💡', title: 'Strategy, Not Just Words', body: 'More than a résumé: a clear positioning strategy for your next opportunity, from bullet points to personal brand.' },
];
---

<section class="section">
  <div class="container-x">
    <div class="max-w-2xl reveal">
      <p class="eyebrow text-violet">Why work with me</p>
      <h2 class="display-2 mt-3">Everything you need to shine.</h2>
      <p class="mt-5 text-lg text-ink/75">Thoughtful, personal, and results-driven — designed with your success in mind.</p>
    </div>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((f, i) => (
        <div class={`card card-hover p-7 reveal reveal-delay-${(i % 3) + 1}`}>
          <div class="w-12 h-12 rounded-2xl bg-lavender-soft grid place-items-center text-2xl">{f.icon}</div>
          <h3 class="mt-5 text-xl">{f.title}</h3>
          <p class="mt-2.5 text-ink/70 leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
