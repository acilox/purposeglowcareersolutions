---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import OutcomesMarquee from '../components/OutcomesMarquee.astro';
import Problem from '../components/Problem.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import WhoFor from '../components/WhoFor.astro';
import WhyChoose from '../components/WhyChoose.astro';
import Process from '../components/Process.astro';
import Services from '../components/Services.astro';
import Compare from '../components/Compare.astro';
import Guarantee from '../components/Guarantee.astro';
import About from '../components/About.astro';
import Testimonials from '../components/Testimonials.astro';
import CareerTips from '../components/CareerTips.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />
  <main id="main">
    <Hero />
    <OutcomesMarquee />
    <Problem />
    <BeforeAfter />
    <WhoFor />
    <WhyChoose />
    <Process />
    <Services />
    <Compare />
    <Guarantee />
    <About />
    <Testimonials />
    <CareerTips />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
